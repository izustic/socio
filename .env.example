# Socio — example environment file
#
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Only variables prefixed with `EXPO_PUBLIC_` are exposed to the app bundle.
# LiveKit API secrets must stay backend-only (Supabase Edge Function secrets).

# Supabase Auth
EXPO_PUBLIC_SUPABASE_URL=demo
EXPO_PUBLIC_SUPABASE_ANON_KEY=demo
# Google OAuth (Supabase)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=demo
GOOGLE_CLIENT_SECRET=demo
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=demo
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=demo
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=demo
EXPO_PUBLIC_GOOGLE_WEB_SECRET=demo

# LiveKit
EXPO_PUBLIC_LIVEKIT_URL=demo
LIVEKIT_API_KEY=demo
LIVEKIT_API_SECRET=demo
